menu "MAIN"

    choice MAIN_LOG_LEVEL
        bool "Log level"
        default MAIN_LOG_DEFAULT_LEVEL_INFO
        help
            Specify how much output to see in logs by default.
            You can set lower verbosity level at runtime using
            esp_log_level_set() function if LOG_DYNAMIC_LEVEL_CONTROL
            is enabled.

            By default, this setting limits which log statements
            are compiled into the program. For example, selecting
            "Warning" would mean that changing log level to "Debug"
            at runtime will not be possible. To allow increasing log
            level above the default at runtime, see the next option.

        config MAIN_LOG_DEFAULT_LEVEL_NONE
            bool "No output"
        config MAIN_LOG_DEFAULT_LEVEL_ERROR
            bool "Error"
        config MAIN_LOG_DEFAULT_LEVEL_WARN
            bool "Warning"
        config MAIN_LOG_DEFAULT_LEVEL_INFO
            bool "Info"
        config MAIN_LOG_DEFAULT_LEVEL_DEBUG
            bool "Debug"
        config MAIN_LOG_DEFAULT_LEVEL_VERBOSE
            bool "Verbose"
    endchoice

    config MAIN_LOG_LEVEL
        int
        default 0 if MAIN_LOG_DEFAULT_LEVEL_NONE
        default 1 if MAIN_LOG_DEFAULT_LEVEL_ERROR
        default 2 if MAIN_LOG_DEFAULT_LEVEL_WARN
        default 3 if MAIN_LOG_DEFAULT_LEVEL_INFO
        default 4 if MAIN_LOG_DEFAULT_LEVEL_DEBUG
        default 5 if MAIN_LOG_DEFAULT_LEVEL_VERBOSE

    config MAIN_MEMORY_SNAPSHOT_ENABLE
        bool "Enable memory snapshot logs"
        default n
        help
            Enable heap snapshot logging at selected checkpoints.

    config MAIN_MEMORY_PERIODIC_MONITOR_ENABLE
        bool "Enable periodic memory monitor task"
        default n
        depends on MAIN_MEMORY_SNAPSHOT_ENABLE
        help
            Start a background task that logs memory usage periodically.

    config MAIN_MEMORY_MONITOR_PERIOD_MS
        int "Memory monitor period [ms]"
        range 1000 600000
        default 10000
        depends on MAIN_MEMORY_PERIODIC_MONITOR_ENABLE

    config MAIN_MEMORY_MONITOR_TASK_STACK
        int "Memory monitor task stack [bytes]"
        range 2048 8192
        default 3072
        depends on MAIN_MEMORY_PERIODIC_MONITOR_ENABLE

    config MAIN_MEMORY_MONITOR_TASK_PRIORITY
        int "Memory monitor task priority"
        range 1 10
        default 2
        depends on MAIN_MEMORY_PERIODIC_MONITOR_ENABLE

endmenu
